{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/product/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Inter|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Inter, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='ActivityBars'] > JSXAttribute > JSXIdentifier[name!=/^(?:data|height|barWidth|gap|key|ref|className|style|children)$/]",
        "message": "<ActivityBars> doesn't accept that prop. Declared props: data, height, barWidth, gap."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|iconLeft|iconRight|prompt|as|href|disabled|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, iconLeft, iconRight, prompt, as, href, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|default|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'default' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Callout'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|title|key|ref|className|style|children)$/]",
        "message": "<Callout> doesn't accept that prop. Declared props: tone, title."
      },
      {
        "selector": "JSXOpeningElement[name.name='Callout'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:tip|info|warn|danger)$/]",
        "message": "<Callout> tone must be one of 'tip' | 'info' | 'warn' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|size|icon|key|ref|className|style|children)$/]",
        "message": "<Chip> doesn't accept that prop. Declared props: tone, size, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:default|active|ok|warn|danger)$/]",
        "message": "<Chip> tone must be one of 'default' | 'active' | 'ok' | 'warn' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Chip> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PaletteItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|icon|onSelect|key|ref|className|style|children)$/]",
        "message": "<PaletteItem> doesn't accept that prop. Declared props: label, hint, icon, onSelect."
      },
      {
        "selector": "JSXOpeningElement[name.name='Metric'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<Metric> doesn't accept that prop. Declared props: value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='PackageCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:pkg|onCopyFlake|onCopyRun|onHistory|key|ref|className|style|children)$/]",
        "message": "<PackageCard> doesn't accept that prop. Declared props: pkg, onCopyFlake, onCopyRun, onHistory."
      },
      {
        "selector": "JSXOpeningElement[name.name='PackageRecord'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|attr|version|description|license|hash|first|last|platforms|insecure|legacy|key|ref|className|style|children)$/]",
        "message": "<PackageRecord> doesn't accept that prop. Declared props: name, attr, version, description, license, hash, first, last, platforms, insecure, legacy."
      },
      {
        "selector": "JSXOpeningElement[name.name='Pagination'] > JSXAttribute > JSXIdentifier[name!=/^(?:page|pageSize|total|hasMore|onPrev|onNext|key|ref|className|style|children)$/]",
        "message": "<Pagination> doesn't accept that prop. Declared props: page, pageSize, total, hasMore, onPrev, onNext."
      },
      {
        "selector": "JSXOpeningElement[name.name='Panel'] > JSXAttribute > JSXIdentifier[name!=/^(?:glass|rail|pad|radius|key|ref|className|style|children)$/]",
        "message": "<Panel> doesn't accept that prop. Declared props: glass, rail, pad, radius."
      },
      {
        "selector": "JSXOpeningElement[name.name='Panel'] > JSXAttribute[name.name='pad'] > Literal[value!=/^(?:none|sm|md|lg)$/]",
        "message": "<Panel> pad must be one of 'none' | 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Panel'] > JSXAttribute[name.name='radius'] > Literal[value!=/^(?:lg|xl|2xl)$/]",
        "message": "<Panel> radius must be one of 'lg' | 'xl' | '2xl'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SearchPrompt'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|onChange|onSubmit|placeholder|command|host|button|key|ref|className|style|children)$/]",
        "message": "<SearchPrompt> doesn't accept that prop. Declared props: value, onChange, onSubmit, placeholder, command, host, button."
      },
      {
        "selector": "JSXOpeningElement[name.name='SegmentOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|icon|key|ref|className|style|children)$/]",
        "message": "<SegmentOption> doesn't accept that prop. Declared props: value, label, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusPill'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|key|ref|className|style|children)$/]",
        "message": "<StatusPill> doesn't accept that prop. Declared props: tone."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusPill'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:ok|warn|danger|idle)$/]",
        "message": "<StatusPill> tone must be one of 'ok' | 'warn' | 'danger' | 'idle'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Terminal'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|key|ref|className|style|children)$/]",
        "message": "<Terminal> doesn't accept that prop. Declared props: title."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute > JSXIdentifier[name!=/^(?:open|icon|key|ref|className|style|children)$/]",
        "message": "<Toast> doesn't accept that prop. Declared props: open, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='VersionBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:version|tone|key|ref|className|style|children)$/]",
        "message": "<VersionBadge> doesn't accept that prop. Declared props: version, tone."
      },
      {
        "selector": "JSXOpeningElement[name.name='VersionBadge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:brand|warn|danger|plain)$/]",
        "message": "<VersionBadge> tone must be one of 'brand' | 'warn' | 'danger' | 'plain'."
      },
      {
        "selector": "JSXOpeningElement[name.name='VersionSpan'] > JSXAttribute > JSXIdentifier[name!=/^(?:version|first|last|insecure|key|ref|className|style|children)$/]",
        "message": "<VersionSpan> doesn't accept that prop. Declared props: version, first, last, insecure."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
